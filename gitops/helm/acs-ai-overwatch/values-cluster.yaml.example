# Optional local override — run: ../../scripts/discover-cluster-values.sh
#
# GitOps does NOT need this file in Git. The in-cluster discovery Job writes
# acs-ai-overwatch-system/acs-ai-overwatch-cluster-config, including:
#   mattermostSiteUrl, mattermostRouteHost (external browser URL)
#
# Use this file only for local `helm template` / debugging with `oc login`.

cluster:
  name: my-openshift-cluster
  appsDomain: apps.cluster.example.com

quayStorage:
  registryCredentials:
    server: quay-quay.apps.cluster.example.com

kagenti:
  api:
    baseUrl: https://kagenti-api.apps.cluster.example.com
  appSource:
    repoUrl: https://github.com/YOUR_ORG/acs-ai-overwatch.git
